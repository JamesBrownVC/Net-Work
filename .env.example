# Every key below is OPTIONAL. With an empty .env the whole fabric runs in mock mode.

# Global switch. Default is "true". Set to "false" to enable live adapters per connector.
MOCK_MODE=true

# --- Anthropic (used from Phase 3 onward) ---
# ANTHROPIC_API_KEY=

# --- Gmail (live adapter, scope: gmail.readonly) ---
# Path to an OAuth token JSON obtained via Google's installed-app flow.
# GOOGLE_TOKEN_PATH=

# --- Google Calendar (live adapter, shares GOOGLE_TOKEN_PATH) ---
# GOOGLE_CALENDAR_ID=primary

# --- Slack as a data source (bot token with channels:history) ---
# SLACK_BOT_TOKEN=

# --- Notion (internal integration token) ---
# NOTION_TOKEN=
# NOTION_DATABASE_ID=

# --- FullEnrich (see config/apis.yaml, verified: false until a human checks docs) ---
# FULLENRICH_API_KEY=

# --- Sillage ---
# SILLAGE_API_KEY=

# --- Gradium (speech to text, EU region, promo code GTM-HACK) ---
# GRADIUM_API_KEY=

# --- Gamma (Phase 4, promo code GAMMA-STATIONF) ---
# GAMMA_API_KEY=
